# ============================================================================
# WSO2 Gateway Federation Demo — configuration
#
# start.sh copies this file to .env on first run. Edit .env (never committed)
# to customise. All values below are sensible local defaults.
# ============================================================================

# ---- Compose project ----
COMPOSE_PROJECT_NAME=gateway-federation-demo
DEMO_NETWORK=gateway_federation_net

# ---- WSO2 API Platform control plane (Publisher / Dev Portal / Admin / Key Manager) ----
WSO2_IMAGE=wso2/wso2am:4.7.0-alpine
CONTROL_PLANE_IMAGE=gateway-federation-control-plane:4.7.0
CONTROL_PLANE_HTTPS_PORT=9443           # management consoles + REST APIs
CONTROL_PLANE_GATEWAY_HTTPS_PORT=8243   # native WSO2 gateway (HTTPS)
CONTROL_PLANE_GATEWAY_HTTP_PORT=8280    # native WSO2 gateway (HTTP)
WSO2_ADMIN_USER=admin
WSO2_ADMIN_PASSWORD=admin

# ---- Kong gateway (Option B) — DB-backed, federated via the KongLocal connector ----
KONG_IMAGE=kong:3.7
KONG_PROXY_PORT=8000                    # API traffic
KONG_ADMIN_PORT=8001                    # Admin API (used by the connector)
KONG_ADMIN_GUI_PORT=8002                # Kong Manager UI

# ---- Mock third-party gateway (Option C) — federated via the HomeGrown connector ----
MOCK_GATEWAY_PORT=8090                  # proxy + admin console + /mock/* API

# ---- Unified mock backend (stands in for every "original" upstream) ----
BACKEND_PORT=4000                       # host-exposed for debugging; internal port is 8080

# ---- Federation demo dashboard ----
DASHBOARD_PORT=3000

# ---- Tooling ----
APICTL_VERSION=4.7.0                    # WSO2 apictl CLI version downloaded by start.sh if missing
